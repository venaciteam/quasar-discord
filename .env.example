# ═══════════════════════════════════
#          Quasar Bot — Config
# ═══════════════════════════════════

# Discord Bot (https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Dashboard OAuth2
# Utilise l'IP locale de ton serveur pour accéder au dashboard depuis tout le réseau.
# Ex: http://192.168.1.100:3050/callback
# L'IP s'affiche dans les logs au démarrage du bot.
# ⚠️  Cette URL doit aussi être ajoutée dans Developer Portal → OAuth2 → Redirects
CALLBACK_URL=http://localhost:3050/callback

# Sécurité — Génère un secret aléatoire : openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_string

# Propriétaire du bot — ID Discord pour les fonctions admin (présence, etc.)
BOT_OWNER_ID=

# Server
PORT=3050

# Feedback — Webhook Discord pour recevoir les bugs/suggestions du dashboard (optionnel)
FEEDBACK_WEBHOOK_URL=

# Stats — URL du hub central pour remonter les stats d'instance (optionnel)
# Les instances envoient un heartbeat toutes les 10 min. Mettre "false" dans STATS_ENABLED pour désactiver.
STATS_URL=https://quasar.vena.city
STATS_ENABLED=true
